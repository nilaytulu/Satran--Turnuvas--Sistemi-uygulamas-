# Satranç Turnuva Yönetim Sistemi — Ortam Değişkenleri Örneği
#
# Bu dosyayı kopyalayın: cp .env.example .env
# Ardından değerleri kendi ortamınıza göre düzenleyin.
# .env dosyasını ASLA Git'e commit etmeyin!

# Flask gizli anahtarı — güçlü, rastgele bir değer kullanın
# Örnek üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=buraya-guclu-rastgele-bir-anahtar-yazin

# Veritabanı bağlantı URL'si
# SQLite (geliştirme):
DATABASE_URL=sqlite:///instance/chess.db
# PostgreSQL (production — Render/Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
